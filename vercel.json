{
  "rewrites": [    { "source": "/api/webhook/whatsapp", "destination": "/api/webhook?provider=whatsapp" },
    { "source": "/api/webhook/wompi",    "destination": "/api/webhook?provider=wompi" },
    { "source": "/api/webhook/kommo",    "destination": "/api/webhook?provider=kommo" },
    { "source": "/api/webhook/sms",      "destination": "/api/webhook?provider=sms" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/gmail?action=watch",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/subscription?action=cron-reminders",
      "schedule": "0 15 * * *"
    }
  ]
}
